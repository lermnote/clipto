/* pages/history/history.wxss */

page {
  background-color: #f0f2f5;
  min-height: 100vh;
}

.page {
  padding: 0 0 120rpx;
}

/* ── 空/加载状态 ── */
.state-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-img {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.25;
  margin-bottom: 28rpx;
}

.state-text {
  font-size: 30rpx;
  color: #999;
  font-weight: 500;
}

.state-sub {
  font-size: 26rpx;
  color: #bbb;
  margin-top: 10rpx;
}

.loading-spin {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #e0e0e0;
  border-top-color: #2C56FF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── 列表 ── */
.list {
  display: flex;
  flex-direction: column;
}

/* ── 单行 ── */
.item {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 图标 */
.item-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  opacity: 0.45;
}

/* 主体 */
.item-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  font-size: 26rpx;
  font-weight: 400;
  color: #1a1a1a;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-tag {
  font-size: 22rpx;
  color: #2C56FF;
  font-weight: 500;
  background: #e8f0ff;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.item-date {
  font-size: 22rpx;
  color: #aaa;
  flex-shrink: 0;
}

/* 操作按钮 */
.item-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.5;
}

.action-del .action-icon {
  opacity: 0.4;
  color: #ff4d4f;
}
